{
  "expo": {
    "name": "ActionVault",
    "slug": "actionvault",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "actionvault",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.actionvault.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.actionvault.app",
      "intentFilters": [
        {
          "action": "android.intent.action.SEND",
          "data": [{ "mimeType": "text/plain" }],
          "category": ["android.intent.category.DEFAULT"]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "./plugins/withShareIntent"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a6c4fcb3-45c5-4176-ab7e-185ef719bcff"
      }
    }
  }
}
